# Copy to .env.local and fill in. setup.sh generates this file automatically
# on a fresh install — you only need to touch it for manual deployments.

# Name shown in the UI header and login screen.
NEXT_PUBLIC_APP_NAME=panelavo

# Required. At least 32 characters in production; sessions are signed with it.
SESSION_SECRET=replace-with-at-least-32-random-characters
# Optional. Falls back to SESSION_SECRET if unset. Used to encrypt stored
# Cloudflare API tokens at rest.
CREDENTIALS_ENCRYPTION_KEY=replace-with-a-separate-32-character-secret
# Optional. Session lifetime in seconds (default 3600).
SESSION_MAX_AGE_SECONDS=3600

# Optional. Seeds the base domain for system subdomains
# (site-<id>.<server-ip>.<base-domain>) on first run; afterwards it is managed
# from the panel itself and stored in .data/panel-settings.json.
#PANEL_BASE_DOMAIN=example.com

# Optional. Seeds the public HTTPS Git repository used by the Settings updater.
# Afterwards it can be changed by a Super Admin and is stored in .data.
#PANEL_UPDATE_REPOSITORY=https://github.com/mehebub648/Panelavo.git

# Everything below is auto-detected and only needed as an override:
#   SERVER_PUBLIC_IP  – the server's public IPv4 (auto-detected)
#   PANEL_DATA_DIR    – where .data state files live (default <app>/.data)
#   PANEL_SELF_DOMAIN – the panel's own site domain, hidden from the site
#                       list (auto-detected from the deploy directory name)
