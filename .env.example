NEXT_PUBLIC_APP_NAME=panelavo
PORT=10443

CLOUDPANEL_BASE_URL=https://127.0.0.1:8443
CLOUDPANEL_VERSION=2.5.4
CLOUDPANEL_TLS_VERIFY=true

# Required. Must be at least 32 characters in production.
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_MAX_AGE_SECONDS=3600
# Optional. Falls back to SESSION_SECRET if unset.
CREDENTIALS_ENCRYPTION_KEY=replace-with-a-separate-32-character-secret

# Initial base domain for website system subdomains
# (site-<id>.<server-ip>.<base domain>). Seeded by setup.sh; the value on the
# panel Settings page (stored in .data/panel-settings.json) takes precedence.
PANEL_BASE_DOMAIN=example.com

# Everything below is auto-detected and only needed as an override:
#   APP_BASE_URL       – not required; CSRF origin is checked against the
#                        request host (X-Forwarded-Host) dynamically.
#   SERVER_PUBLIC_IP   – not required; the public IP is auto-detected.
#   NODE_ENV           – do not set; `next start` forces production.
