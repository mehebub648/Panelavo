+        if (stdout.length < 500_000) stdout += chunk.toString("utf8");
+      });
+      child.stderr.on("data", (chunk: Buffer) => {
+        if (stderr.length < 500_000) stderr += chunk.toString("utf8");
+      });
+      const timeout = setTimeout(
