@@ -0,0 +1,580 @@
+import { spawn } from "node:child_process";
+import { constants } from "node:fs";
+import {
+  access,
+  lstat,
+  mkdir,
+  readdir,
+  realpath,
+  stat,
+} from "node:fs/promises";
+import { basename, dirname, isAbsolute, join, resolve, sep } from "node:path";
+import { getCloudPanelClient } from "@/server/cloudpanel";
+import { AppError } from "@/server/cloudpanel/errors";
+import type { CloudPanelSession, CloudPanelSite } from "@/types/cloudpanel";
+
+export type ArchiveFormat = "zip" | "7z" | "rar";
+
+type FileManagerItem = {
+  name: string;
+  type: "file" | "directory";
+  size: number;
+  modified: string;
+  permissions?: string;
+};
+
+type FileManagerData = {
+  path: string;
+  relativePath?: string;
+  items?: FileManagerItem[];
+};
+
+const archiveExtensions: Record<ArchiveFormat, string> = {
+  zip: ".zip",
+  "7z": ".7z",
+  rar: ".rar",
+};
+
+const executableCandidates = {
+  zip: ["/usr/bin/zip", "/usr/local/bin/zip"],
+  unzip: ["/usr/bin/unzip", "/usr/local/bin/unzip"],
+  sevenZip: [
+    "/usr/bin/7z",
+    "/usr/local/bin/7z",
+    "/usr/bin/7za",
+    "/usr/local/bin/7za",
+  ],
+  rar: ["/usr/bin/rar", "/usr/local/bin/rar"],
+  unrar: ["/usr/bin/unrar", "/usr/local/bin/unrar"],
+  bsdtar: ["/usr/bin/bsdtar", "/usr/local/bin/bsdtar"],
+  mkdir: ["/usr/bin/mkdir", "/bin/mkdir"],
+} as const;
+
+const archiveTimeoutMs = 30 * 60_000;
+
+export function isDirectArchiveAction(input: unknown) {
+  if (!input || typeof input !== "object" || !("action" in input)) return false;
+  const action = String((input as { action?: unknown }).action ?? "");
+  return action === "compress" || action === "extract";
+}
+
+export async function manageFileArchive(
+  session: CloudPanelSession,
+  domain: string,
+  input: Record<string, unknown>,
+): Promise<FileManagerData> {
+  const site = await getAuthorizedSite(session, domain);
+  if (!site.siteUser)
+    throw new AppError(
+      "INVALID_REQUEST",
+      "This website does not have a site user.",
+      400,
+    );
+
+  const base = await safeBaseForSite(site);
+  const currentRelative = String(input.path ?? "");
+  const directory = await safeExistingPath(base, currentRelative, "directory");
+  const name = safeName(String(input.name ?? ""));
+  const source = await safeExistingPath(base, join(currentRelative, name));
+  const action = String(input.action ?? "");
+
+  if (action === "compress") {
+    const format = archiveFormat(String(input.format ?? ""), name);
+    const archiveName = normalizeArchiveName(
+      String(input.archiveName ?? ""),
+      name,
+      format,
+    );
+    const destination = await safeNewPath(
+      base,
+      join(currentRelative, archiveName),
+    );
+    await ensureDoesNotExist(
+      destination,
+      "An archive with that name already exists.",
+    );
+    await compressPath(site.siteUser, format, source, destination);
+    return listDirectory(base, currentRelative);
+  }
+
+  if (action === "extract") {
+    const format = archiveFormat(String(input.format ?? ""), name);
+    const destination = await safeDestinationDirectory(
+      base,
+      directory,
+      String(input.destination ?? "."),
+      site.siteUser,
+    );
+    await extractArchive(site.siteUser, format, source, destination);
+    return listDirectory(base, relativeFromBase(base, destination));
+  }
+
+  throw new AppError("INVALID_REQUEST", "Unknown archive action.", 400);
+}
+
+async function getAuthorizedSite(session: CloudPanelSession, domain: string) {
+  const sites = await getCloudPanelClient().listSites(session);
+  const site = sites.find((item) => item.domain === domain);
+  if (!site) throw new AppError("SITE_NOT_FOUND", "Website not found.", 404);
+  return site;
+}
+
+async function safeBaseForSite(site: CloudPanelSite) {
+  if (!site.siteUser || !/^[a-z_][a-z0-9_-]*[$]?$/i.test(site.siteUser))
+    throw new AppError(
+      "INVALID_REQUEST",
+      "This website has an invalid site user.",
+      400,
+    );
+  const base = await realpath(join("/home", site.siteUser));
+  const stats = await stat(base);
+  if (!stats.isDirectory())
+    throw new AppError(
+      "SITE_NOT_FOUND",
+      "Website files could not be found.",
+      404,
+    );
+  return base;
+}
+
+function safeName(name: string) {
+  const value = name.trim();
+  if (
+    !value ||
+    value === "." ||
+    value === ".." ||
+    basename(value) !== value ||
+    value.includes("\\")
+  )
+    throw new AppError(
+      "INVALID_REQUEST",
+      "Choose a valid file or folder name.",
+      400,
+    );
+  return value;
+}
+
+function trimRelative(relative: string) {
+  const value = relative.replace(/\\/g, "/").replace(/^\/+|\/+$/g, "");
+  if (!value) return "";
+  const parts = value.split("/");
+  if (parts.some((part) => !part || part === "." || part === ".."))
+    throw new AppError("INVALID_REQUEST", "Choose a valid folder path.", 400);
+  return parts.join("/");
+}
+
+async function safeExistingPath(
+  base: string,
+  relative: string,
+  expected?: "directory" | "file",
+) {
+  const clean = trimRelative(relative);
+  const target = await realpath(clean ? join(base, clean) : base);
+  ensureInside(base, target);
+  if (expected) {
+    const stats = await stat(target);
+    if (
+      (expected === "directory" && !stats.isDirectory()) ||
+      (expected === "file" && !stats.isFile())
+    )
+      throw new AppError(
+        "INVALID_REQUEST",
+        "The selected path is not valid.",
+        400,
+      );
+  }
+  return target;
+}
+
+async function safeNewPath(base: string, relative: string) {
+  const clean = trimRelative(relative);
+  if (!clean)
+    throw new AppError("INVALID_REQUEST", "Choose a valid archive name.", 400);
+  const parent = await realpath(dirname(join(base, clean)));
+  ensureInside(base, parent);
+  const target = join(parent, basename(clean));
+  ensureInside(base, target);
+  return target;
+}
+
+async function safeDestinationDirectory(
+  base: string,
+  currentDirectory: string,
+  destination: string,
+  siteUser: string,
+) {
+  const requested = destination.trim() || ".";
+  if (isAbsolute(requested) || requested.includes("\0"))
+    throw new AppError(
+      "INVALID_REQUEST",
+      "Use a relative destination folder.",
+      400,
+    );
+
+  const target = resolve(currentDirectory, requested);
+  ensureInside(base, target);
+
+  const parent = await nearestExistingParent(target);
+  ensureInside(base, parent);
+  try {
+    const current = await lstat(target);
+    if (!current.isDirectory())
+      throw new AppError(
+        "INVALID_REQUEST",
+        "The destination must be a folder.",
+        400,
+      );
+  } catch (error) {
+    if (error instanceof AppError) throw error;
+    const mkdirExecutable = await findExecutable(executableCandidates.mkdir);
+    if (mkdirExecutable)
+      await runAsSiteUser(siteUser, mkdirExecutable, ["-p", target], {
+        timeout: 30_000,
+      });
+    else await mkdir(target, { recursive: true, mode: 0o770 });
+  }
+
+  const realTarget = await realpath(target);
+  ensureInside(base, realTarget);
+  return realTarget;
+}
+
+async function nearestExistingParent(target: string) {
+  let current = target;
+  for (;;) {
+    try {
+      const stats = await stat(current);
+      if (!stats.isDirectory())
+        throw new AppError(
+          "INVALID_REQUEST",
+          "The destination path is not valid.",
+          400,
+        );
+      return await realpath(current);
+    } catch (error) {
+      if (error instanceof AppError) throw error;
+      const next = dirname(current);
+      if (next === current) throw error;
+      current = next;
+    }
+  }
+}
+
+function ensureInside(base: string, target: string) {
+  if (target !== base && !target.startsWith(`${base}${sep}`))
+    throw new AppError(
+      "INVALID_REQUEST",
+      "That path is outside the website file area.",
+      400,
+    );
+}
+
+function relativeFromBase(base: string, target: string) {
+  if (target === base) return "";
+  ensureInside(base, target);
+  return target
+    .slice(base.length + 1)
+    .split(sep)
+    .join("/");
+}
+
+async function ensureDoesNotExist(path: string, message: string) {
+  try {
+    await lstat(path);
+    throw new AppError("INVALID_REQUEST", message, 409);
+  } catch (error) {
+    if (error instanceof AppError) throw error;
+  }
+}
+
+function archiveFormat(value: string, fileName: string): ArchiveFormat {
+  const normalized = value.toLowerCase();
+  if (normalized === "zip" || normalized === "7z" || normalized === "rar")
+    return normalized;
+  const lowerName = fileName.toLowerCase();
+  if (lowerName.endsWith(".7z")) return "7z";
+  if (lowerName.endsWith(".rar")) return "rar";
+  return "zip";
+}
+
+function normalizeArchiveName(
+  name: string,
+  sourceName: string,
+  format: ArchiveFormat,
+) {
+  const extension = archiveExtensions[format];
+  let value = (name.trim() || `${sourceName}${extension}`).replace(/\\/g, "/");
+  if (!value || value === "." || value === ".." || basename(value) !== value)
+    throw new AppError("INVALID_REQUEST", "Choose a valid archive name.", 400);
+
+  const supportedExtension = Object.values(archiveExtensions).find((item) =>
+    value.toLowerCase().endsWith(item),
+  );
+  if (supportedExtension && supportedExtension !== extension) {
+    value = value.slice(0, -supportedExtension.length) + extension;
+  } else if (!value.toLowerCase().endsWith(extension)) {
+    value += extension;
+  }
+  return safeName(value);
+}
+
+async function compressPath(
+  siteUser: string,
+  format: ArchiveFormat,
+  source: string,
+  destination: string,
+) {
+  const cwd = dirname(source);
+  const entry = basename(source);
+  if (format === "zip") {
+    const zip = await requireExecutable(
+      executableCandidates.zip,
+      "ZIP compression needs the zip command installed.",
+    );
+    await runAsSiteUser(siteUser, zip, ["-r", "-q", destination, entry], {
+      cwd,
+      timeout: archiveTimeoutMs,
+    });
+    return;
+  }
+  if (format === "7z") {
+    const sevenZip = await requireExecutable(
+      executableCandidates.sevenZip,
+      "7z compression needs 7-Zip or p7zip installed.",
+    );
+    await runAsSiteUser(
+      siteUser,
+      sevenZip,
+      ["a", "-t7z", "-bd", destination, entry],
+      { cwd, timeout: archiveTimeoutMs },
+    );
+    return;
+  }
+  const rar = await requireExecutable(
+    executableCandidates.rar,
+    "RAR compression needs the rar command installed.",
+  );
+  await runAsSiteUser(siteUser, rar, ["a", "-r", "-idq", destination, entry], {
+    cwd,
+    timeout: archiveTimeoutMs,
+  });
+}
+
+async function extractArchive(
+  siteUser: string,
+  format: ArchiveFormat,
+  source: string,
+  destination: string,
+) {
+  await validateArchiveEntries(siteUser, source);
+
+  if (format === "zip") {
+    const unzip = await findExecutable(executableCandidates.unzip);
+    if (unzip) {
+      await runAsSiteUser(
+        siteUser,
+        unzip,
+        ["-q", "-n", source, "-d", destination],
+        {
+          timeout: archiveTimeoutMs,
+        },
+      );
+      return;
+    }
+  }
+
+  if (format === "7z") {
+    const sevenZip = await findExecutable(executableCandidates.sevenZip);
+    if (sevenZip) {
+      await runAsSiteUser(
+        siteUser,
+        sevenZip,
+        ["x", "-y", "-aos", `-o${destination}`, source],
+        {
+          timeout: archiveTimeoutMs,
+        },
+      );
+      return;
+    }
+  }
+
+  if (format === "rar") {
+    const unrar = await findExecutable(executableCandidates.unrar);
+    if (unrar) {
+      await runAsSiteUser(
+        siteUser,
+        unrar,
+        ["x", "-o-", source, `${destination}/`],
+        {
+          timeout: archiveTimeoutMs,
+        },
+      );
+      return;
+    }
+  }
+
+  const bsdtar = await requireExecutable(
+    executableCandidates.bsdtar,
+    "Archive extraction needs unzip, 7z, unrar, or bsdtar installed.",
+  );
+  await runAsSiteUser(
+    siteUser,
+    bsdtar,
+    ["-xpf", source, "-C", destination, "-k"],
+    {
+      timeout: archiveTimeoutMs,
+    },
+  );
+}
+
+async function validateArchiveEntries(siteUser: string, source: string) {
+  const bsdtar = await findExecutable(executableCandidates.bsdtar);
+  let output = "";
+  if (bsdtar)
+    output = await runAsSiteUser(siteUser, bsdtar, ["-tf", source], {
+      timeout: 120_000,
+    });
+  else {
+    const unzip = await requireExecutable(
+      executableCandidates.unzip,
+      "Archive extraction needs a tool that can inspect archive contents.",
+    );
+    output = await runAsSiteUser(siteUser, unzip, ["-Z1", source], {
+      timeout: 120_000,
+    });
+  }
+
+  for (const entry of output.split(/\r?\n/)) {
+    const normalized = entry.replace(/\\/g, "/").trim();
+    if (!normalized) continue;
+    const parts = normalized.split("/");
+    if (
+      normalized.startsWith("/") ||
+      parts.some((part) => part === ".." || part === ".")
+    ) {
+      throw new AppError(
+        "INVALID_REQUEST",
+        "This archive contains unsafe paths.",
+        400,
+      );
+    }
+  }
+}
+
+async function listDirectory(
+  base: string,
+  relative: string,
+): Promise<FileManagerData> {
+  const directory = await safeExistingPath(base, relative, "directory");
+  const entries = await readdir(directory);
+  const items = await Promise.all(
+    entries
+      .filter((name) => name !== "." && name !== "..")
+      .map(async (name) => {
+        const path = join(directory, name);
+        const itemStat = await lstat(path);
+        return {
+          name,
+          type: itemStat.isDirectory() ? "directory" : "file",
+          size: itemStat.isFile() ? itemStat.size : 0,
+          modified: itemStat.mtime.toISOString(),
+          permissions: (itemStat.mode & 0o7777).toString(8).padStart(4, "0"),
+        } satisfies FileManagerItem;
+      }),
+  );
+
+  items.sort((a, b) => {
+    if (a.type !== b.type) return a.type === "directory" ? -1 : 1;
+    return a.name.localeCompare(b.name, undefined, { sensitivity: "base" });
+  });
+
+  return { path: base, relativePath: trimRelative(relative), items };
+}
+
+async function findExecutable(candidates: readonly string[]) {
+  for (const candidate of candidates) {
+    try {
+      await access(candidate, constants.X_OK);
+      return candidate;
+    } catch {}
+  }
+  return null;
+}
+
+async function requireExecutable(
+  candidates: readonly string[],
+  message: string,
+) {
+  const executable = await findExecutable(candidates);
+  if (!executable) throw new AppError("INVALID_REQUEST", message, 400);
+  return executable;
+}
+
+function runAsSiteUser(
+  siteUser: string,
+  executable: string,
+  args: string[],
+  options: { cwd?: string; timeout?: number } = {},
+) {
+  return new Promise<string>((resolvePromise, reject) => {
+    const child = spawn(
+      "/usr/bin/sudo",
+      ["-n", "-u", siteUser, executable, ...args],
+      {
+        cwd: options.cwd,
+        shell: false,
+        stdio: ["ignore", "pipe", "pipe"],
+      },
+    );
+    let stdout = "";
+    let stderr = "";
+    const timeout = setTimeout(
+      () => child.kill("SIGKILL"),
+      options.timeout ?? 120_000,
+    );
+
+    child.stdout.on("data", (chunk: Buffer) => {
+      if (stdout.length < 5_000_000) stdout += chunk.toString("utf8");
+    });
+    child.stderr.on("data", (chunk: Buffer) => {
+      if (stderr.length < 500_000) stderr += chunk.toString("utf8");
+    });
+    child.on("error", () => {
+      clearTimeout(timeout);
+      reject(
+        new AppError(
+          "INVALID_REQUEST",
+          "The archive command could not be started.",
+          500,
+        ),
+      );
+    });
+    child.on("close", (code, signal) => {
+      clearTimeout(timeout);
+      if (code === 0) {
+        resolvePromise(stdout);
+        return;
+      }
+      if (signal === "SIGKILL") {
+        reject(
+          new AppError(
+            "REQUEST_TIMEOUT",
+            "The archive operation took too long to finish.",
+            504,
+          ),
+        );
+        return;
+      }
+      const detail = (stderr || stdout).split(/\r?\n/).find(Boolean);
+      reject(
+        new AppError(
+          "INVALID_REQUEST",
+          detail
+            ? `Archive operation failed: ${detail}`
+            : "Archive operation failed.",
+          400,
+        ),
+      );
+    });
+  });
+}
